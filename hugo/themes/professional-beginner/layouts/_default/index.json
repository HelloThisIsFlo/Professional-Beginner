{{ $pages := where .Site.RegularPages "Section" "posts" }}
{
  "version": "https://jsonfeed.org/version/1",
  "title": "{{ .Site.Title }}",
  "home_page_url": "{{ .Site.BaseURL }}",
  "feed_url": "{{ .Site.BaseURL }}allPosts.json",
  "items": [
    {{ range $i, $p := $pages }}{{ if $i }},{{ end }}
    {
      "title": {{ $p.Title | jsonify }},
      "date_published": "{{ $p.Date.Format "2006-01-02T15:04:05Z07:00" }}",
      "url": "{{ $p.Permalink }}",
      "content_html": {{ $p.Content | jsonify }},
      "summary": {{ $p.Summary | plainify | jsonify }}
    }
    {{ end }}
  ]
}
